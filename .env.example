# Copy this file to .env for local development. Blank Shopify credentials select
# the built-in local store simulator; a blank Gemini key selects the deterministic
# recommender. Never commit your populated .env file.

# Shopify single-store app (required only for a live dev store). The domain is
# the *.myshopify.com hostname only (no https://, path, or trailing slash).
# Configure permissions as required scopes, not optional scopes. Use ONE mode:
# 1) Current Dev Dashboard apps: domain + API key/client ID + API secret. The
#    server exchanges these for a short-lived token and refreshes it.
# 2) Legacy custom apps: domain + static Admin access token.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2026-07

# Google Gemini. Blank keeps the local simulator deterministic; with a live
# Shopify store, blank fails inert unless the merchant explicitly enables the
# labeled fallback formula in Settings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_CHUNK_DELAY_SECONDS=0.25

# Dashboard HTTP Basic authentication. Development allows a blank password.
# Production requires a password of at least 16 characters and fails closed.
APP_USERNAME=admin
APP_PASSWORD=

# Local PostgreSQL. Docker Compose overrides DATABASE_HOST to `db`.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=mglogics_development
DATABASE_NAME_TEST=mglogics_test

# Production/PaaS examples (set these in the platform secret manager, not in
# the local .env copied from this file).
# DATABASE_URL=postgresql://user:password@host:5432/database
# SECRET_KEY_BASE=generate-with-bin-rails-secret
# RAILS_LOG_LEVEL=info
# RAILS_MAX_THREADS=5
# WEB_CONCURRENCY=1
# JOB_CONCURRENCY=1

# Set true only when running one web instance without a dedicated `bin/jobs`
# worker. Leave unset when a separate worker process is configured.
# SOLID_QUEUE_IN_PUMA=true
# ASSUME_SSL=true
# FORCE_SSL=true
